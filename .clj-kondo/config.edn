{;; Construction macros retain their source forms, so lint equivalent ordinary
 ;; forms instead of expanding their implementation details.
 :hooks {:analyze-call
         {karcarthy/agent          hooks.karcarthy/agent
          karcarthy.agent/agent    hooks.karcarthy/agent
          karcarthy/defagent       hooks.karcarthy/defagent
          karcarthy.agent/defagent hooks.karcarthy/defagent
          karcarthy/tool           hooks.karcarthy/tool
          karcarthy.tool/tool      hooks.karcarthy/tool
          karcarthy/deftool        hooks.karcarthy/deftool
          karcarthy.tool/deftool   hooks.karcarthy/deftool}}

 ;; Examples are intentionally organized as task folders with `main.clj`
 ;; entry points and loaded by the repository example dispatcher.
 :config-in-ns {example.architect
                {:linters {:namespace-name-mismatch {:level :off}}}
                example.basic
                {:linters {:namespace-name-mismatch {:level :off}}}
                example.chat
                {:linters {:namespace-name-mismatch {:level :off}}}
                example.coding
                {:linters {:namespace-name-mismatch {:level :off}}}
                example.composition
                {:linters {:namespace-name-mismatch {:level :off}}}}}
